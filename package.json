{
  "name": "autopilotv",
  "version": "1.7.1",
  "description": "AutopilotV — agent orchestrator for software development and PR reviewing",
  "main": "./out/main/index.js",
  "author": "justinwoodring",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JustinWoodring/AutopilotV.git"
  },
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/rebuild-native.js --target=electron",
    "dev": "electron-vite dev",
    "prebuild": "node ./scripts/rebuild-native.js --target=electron",
    "build": "electron-vite build",
    "prestart": "node ./scripts/rebuild-native.js --target=electron",
    "start": "electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pretest": "node ./scripts/rebuild-native.js --target=node",
    "test": "vitest run",
    "pretest:watch": "node ./scripts/rebuild-native.js --target=node",
    "test:watch": "vitest",
    "rebuild": "node ./scripts/rebuild-native.js --target=electron",
    "postinstall": "node ./scripts/patch-better-sqlite3.js && node node_modules/electron/install.js && node ./scripts/rebuild-native.js",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "node-pty": "^1.1.0",
    "openai": "^4.77.0",
    "yaml": "^2.9.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.justinwoodring.autopilotv",
    "productName": "AutopilotV",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterPack": "build/afterPack.cjs",
    "publish": [
      {
        "provider": "github",
        "owner": "JustinWoodring",
        "repo": "AutopilotV"
      }
    ],
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        "AppImage"
      ]
    }
  }
}
